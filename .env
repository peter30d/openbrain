OPENBRAIN_ENV=dev
OPENBRAIN_HOST=127.0.0.1
OPENBRAIN_PORT=8094

OPENBRAIN_DATABASE_URL=postgresql+psycopg://openbrain:Pb4openbrain@127.0.0.1:5432/openbrain
OPENBRAIN_ARCHIVE_DIR=/opt/openbrain/archive
OPENBRAIN_LOG_LEVEL=INFO

OPENBRAIN_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENBRAIN_EMBED_DIM=384

OPENBRAIN_ENABLE_BRIAN_REPO=true
OPENBRAIN_ENABLE_BRIAN_MCP=false

OPENBRAIN_BRIAN_REPO_DIR=/opt/openbrain/external/brianmadden-ai
OPENBRAIN_BRIAN_SITE_URL=https://brianmadden.ai
OPENBRAIN_BRIAN_MCP_URL=https://brianmadden.ai/mcp
OPENBRAIN_BRIAN_TIMEOUT_SECONDS=20

